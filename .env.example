MQTT_URL=mqtt://<mqtt-host>:1883
MQTT_USERNAME=<mqtt-user>
MQTT_PASSWORD=<mqtt-password>
MQTT_TOPICS=frigate/events
HOME_ASSISTANT_OPENCLAW_TOPIC=frigate-openclaw-notifier/openclaw/send
HOME_ASSISTANT_OPENCLAW_CONTROL_COMMAND_TOPIC=frigate-openclaw-notifier/openclaw/set
HOME_ASSISTANT_OPENCLAW_CONTROL_STATE_TOPIC=frigate-openclaw-notifier/openclaw/state
HOME_ASSISTANT_OPENCLAW_DEFAULT_ENABLED=true

ALERT_CONTROL_COMMAND_TOPIC=frigate-openclaw-notifier/alerts/set
ALERT_CONTROL_STATE_TOPIC=frigate-openclaw-notifier/alerts/state
ALERT_CONTROL_DEFAULT_ENABLED=true
ALERT_CONTROL_CAMERA_TOPIC_PREFIX=frigate-openclaw-notifier/alerts

HOME_ASSISTANT_DISCOVERY_ENABLED=true
HOME_ASSISTANT_DISCOVERY_PREFIX=homeassistant
HOME_ASSISTANT_DEVICE_ID=frigate_openclaw_notifier
HOME_ASSISTANT_DEVICE_NAME=Frigate OpenClaw Notifier

FRIGATE_BASE_URL=http://<frigate-host>:5000/api
FRIGATE_USE_LOCAL_MEDIA=false
FRIGATE_LOCAL_CLIPS_DIR=

OPENCLAW_BIN=openclaw
OPENCLAW_CHANNEL=whatsapp
OPENCLAW_ACCOUNT=
OPENCLAW_TARGET=<E164_OR_GROUP_JID>
OPENCLAW_GROUP_ID=
OPENCLAW_TIMEOUT_MS=120000

NOTIFY_ON_REVIEW_NEW=false
NOTIFY_ON_REVIEW_UPDATE=false
NOTIFY_ON_REVIEW_END=false

SEND_SNAPSHOT=true
SEND_CLIP=true

MIN_SEVERITIES=alert
ALLOWED_CAMERAS=<camera-1>,<camera-2>
ALLOWED_OBJECTS=person,car
BLOCKED_ZONES=
COOLDOWN_SECONDS=90

MEDIA_TMP_DIR=/tmp/frigate-openclaw
MEDIA_RETENTION_SECONDS=600
FFMPEG_BIN=ffmpeg
VIDEO_PROCESS_TIMEOUT_MS=120000
CLIP_RETRY_ATTEMPTS=3
CLIP_RETRY_DELAY_MS=3000
FRIGATE_FETCH_TIMEOUT_MS=15000
MESSAGE_TIME_ZONE=America/Santiago
LOG_LEVEL=info
